# Database
DATABASE_URL="postgresql://user:password@localhost:5432/truck4u"

# Redis
REDIS_URL="redis://localhost:6379"

# JWT
JWT_SECRET="your-super-secret-jwt-key-change-in-production"

# Server
PORT=4000
NODE_ENV=development
FRONTEND_URL="http://localhost:3000"
API_URL="http://localhost:4000"

# Storage Configuration
# Options: 'local' (development), 'r2' (Cloudflare R2), 's3' (AWS S3)
STORAGE_PROVIDER="local"

# Cloudflare R2 Configuration (if STORAGE_PROVIDER=r2)
R2_ACCOUNT_ID="your-cloudflare-account-id"
R2_ACCESS_KEY_ID="your-r2-access-key"
R2_SECRET_ACCESS_KEY="your-r2-secret-key"
R2_BUCKET_NAME="truck4u-documents"
R2_PUBLIC_URL="https://cdn.truck4u.tn"  # Optional: for public buckets

# AWS S3 Configuration (if STORAGE_PROVIDER=s3)
AWS_ACCESS_KEY_ID="your-aws-access-key"
AWS_SECRET_ACCESS_KEY="your-aws-secret-key"
AWS_REGION="eu-west-1"
S3_BUCKET_NAME="truck4u-documents"
S3_PUBLIC_URL="https://cdn.truck4u.tn"  # Optional: for public buckets or CloudFront

# Paymee Integration
PAYMEE_API_URL="https://api.paymee.tn"
PAYMEE_API_KEY="your-paymee-api-key"
PAYMEE_WEBHOOK_SECRET="your-paymee-webhook-secret"

# Flouci Integration
FLOUCI_API_URL="https://developers.flouci.com"
FLOUCI_APP_PUBLIC="your-flouci-app-public"
FLOUCI_APP_SECRET="your-flouci-app-secret"

# Twilio (for SMS/OTP)
TWILIO_ACCOUNT_SID="your-twilio-account-sid"
TWILIO_AUTH_TOKEN="your-twilio-auth-token"
TWILIO_PHONE_NUMBER="+1234567890"

# Web Push (for notifications)
VAPID_PUBLIC_KEY="your-vapid-public-key"
VAPID_PRIVATE_KEY="your-vapid-private-key"
VAPID_SUBJECT="mailto:your-email@truck4u.tn"
